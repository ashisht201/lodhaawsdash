# backend/.env.example
# Copy to .env for local dev. In Render, set these as Environment Variables.

# Render provides this automatically when you link a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Your AWS IAM read-only user credentials
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1

# Admin account seeded on first start (change immediately after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Frontend URL for CORS (your GitHub Pages URL)
FRONTEND_URL=https://YOUR_GITHUB_USERNAME.github.io

# SMTP for alert emails (optional — alerts log to console if omitted)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="AWS Dashboard <you@gmail.com>"
